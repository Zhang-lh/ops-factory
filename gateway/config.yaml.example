# Gateway configuration
# Priority: environment variable > config.yaml value > default
# Required fields will cause startup failure if missing from both sources.

server:
  host: "0.0.0.0"           # env: GATEWAY_HOST
  port: 3000                 # env: GATEWAY_PORT
  secretKey: ""              # env: GATEWAY_SECRET_KEY  [REQUIRED]
  corsOrigin: "*"            # env: CORS_ORIGIN

# TLS/HTTPS (optional, both cert and key required to enable)
tls:
  cert: ""                   # env: TLS_CERT  — path to certificate file
  key: ""                    # env: TLS_KEY   — path to private key file

# File paths (auto-detected if empty)
paths:
  projectRoot: ""            # env: PROJECT_ROOT  — repo root, auto-detected
  agentsDir: ""              # env: AGENTS_DIR    — default: <projectRoot>/gateway/agents
  usersDir: ""               # env: USERS_DIR     — default: <projectRoot>/gateway/users
  goosedBin: "goosed"        # env: GOOSED_BIN    — goosed binary name or path

# Per-user instance idle reaping
idle:
  timeoutMinutes: 15         # env: IDLE_TIMEOUT_MS (in milliseconds, overrides this)
  checkIntervalMs: 60000     # env: IDLE_CHECK_INTERVAL_MS

# File upload limits
upload:
  maxFileSizeMb: 10          # env: MAX_UPLOAD_FILE_SIZE_MB
  maxImageSizeMb: 5          # env: MAX_UPLOAD_IMAGE_SIZE_MB
  retentionHours: 24         # env: UPLOAD_RETENTION_HOURS

# OnlyOffice document preview
officePreview:
  enabled: false             # env: OFFICE_PREVIEW_ENABLED
  onlyofficeUrl: "http://localhost:8080"              # env: ONLYOFFICE_URL
  fileBaseUrl: "http://host.docker.internal:3000"     # env: ONLYOFFICE_FILE_BASE_URL

# Vision / image processing (global defaults, per-agent config.yaml can override)
vision:
  mode: "passthrough"        # env: VISION_MODE  — off | passthrough | preprocess
  provider: ""               # env: VISION_PROVIDER (fallback: GOOSE_PROVIDER)
  model: ""                  # env: VISION_MODEL (fallback: GOOSE_MODEL)
  apiKey: ""                 # env: VISION_API_KEY (fallback: OPENAI_API_KEY, LITELLM_API_KEY)
  baseUrl: ""                # env: VISION_BASE_URL (fallback: OPENAI_HOST, LITELLM_HOST)
  maxTokens: 1024            # env: VISION_MAX_TOKENS
  prompt: ""                 # env: VISION_PROMPT  — custom prompt (has built-in default)

# Langfuse observability (all three required to enable, otherwise disabled)
langfuse:
  host: ""                   # env: LANGFUSE_HOST
  publicKey: ""              # env: LANGFUSE_PUBLIC_KEY
  secretKey: ""              # env: LANGFUSE_SECRET_KEY
